<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - iOS Style -->
    <style name="Theme.JinnChat" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        
        <!-- Background color -->
        <item name="android:colorBackground">@color/background</item>
        <item name="backgroundColor">@color/background</item>
        
        <!-- Surface color -->
        <item name="colorSurface">@color/surface</item>
        
        <!-- Error color -->
        <item name="colorError">@color/error</item>
        
        <!-- Window background -->
        <item name="android:windowBackground">@color/background</item>
        
        <!-- Edit text style -->
        <item name="editTextStyle">@style/EditTextStyle</item>
        
        <!-- Button style -->
        <item name="materialButtonStyle">@style/ButtonStyle</item>
    </style>
    
    <!-- iOS Style EditText -->
    <style name="EditTextStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">@drawable/input_background_ios</item>
        <item name="android:padding">14dp</item>
    </style>
    
    <!-- iOS Style Button -->
    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:padding">14dp</item>
    </style>
    
    <!-- Glass Effect Card Style -->
    <style name="GlassCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>
    
    <!-- Message Bubble Style - Sent -->
    <style name="MessageBubbleSent">
        <item name="android:background">@drawable/message_bubble_sent</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <!-- Message Bubble Style - Received -->
    <style name="MessageBubbleReceived">
        <item name="android:background">@drawable/message_bubble_received</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <!-- iOS Style Header Text -->
    <style name="HeaderTextStyle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- iOS Style Subtitle Text -->
    <style name="SubtitleTextStyle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <!-- Gradient Button Style -->
    <style name="GradientButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_gradient</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">14dp</item>
    </style>
</resources>
